# MCU class and specific type
MCU STM32G4xx STM32G474xx

# Board ID
APJ_BOARD_ID TARGET_HW_SPS_BFD_SPRAYSYSTEM

# 12MHz crystal
OSCILLATOR_HZ 0

# bootloader is installed at zero offset
FLASH_RESERVE_START_KB 0

# Flash size
FLASH_SIZE_KB 512

# 2 sectors for bootloader, 2 for storage
FLASH_BOOTLOADER_LOAD_KB 64

# setup build for a peripheral firmware
env AP_PERIPH 1

define HAL_USE_SERIAL FALSE

# CAN bus order
CAN_ORDER 1 2

# CAN buses
PA11 CAN1_RX CAN1
PA12 CAN1_TX CAN1